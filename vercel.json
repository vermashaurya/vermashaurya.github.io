{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "pages.shaurya.online"
        }
      ],
      "destination": "/pages/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "pages.shaurya.online"
        }
      ],
      "destination": "/pages/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "pages.shaurya.online"
        }
      ],
      "destination": "https://pages.shaurya.online/pages/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.shaurya.online"
        }
      ],
      "destination": "https://shaurya.online/:path*",
      "permanent": true
    },
    {
      "source": "/pages/:path*",
      "has": [
        {
          "type": "host",
          "value": "shaurya.online"
        }
      ],
      "destination": "https://pages.shaurya.online/:path*",
      "permanent": true
    },
    { "source": "/github", "destination": "https://github.com/vermashaurya", "permanent": false },
    { "source": "/linkedin", "destination": "https://linkedin.com/in/verma-shaurya", "permanent": false },
    { "source": "/resume", "destination": "/assets/shaurya-verma-resume.pdf", "permanent": false }
  ]
}
